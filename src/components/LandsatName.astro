<script
  src="https://cdn.jsdelivr.net/npm/qrcode/build/qrcode.min.js"
  crossorigin="anonymous"
  referrerpolicy="no-referrer"
></script>

<script
  src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"
  crossorigin="anonymous"
  referrerpolicy="no-referrer"
></script>

<script define:vars={{ initialWordSerialized, initialSequenceSerialized, letterDataSerialized, badWordsSerialized, badWordResponsesSerialized, imagesBasePath }}>
  const letterData = JSON.parse(letterDataSerialized);
  const badWords = JSON.parse(badWordsSerialized);
  const badWordResponses = JSON.parse(badWordResponsesSerialized);
  const initialWord = JSON.parse(initialWordSerialized);
  const initialSequence = JSON.parse(initialSequenceSerialized);
  let imageSelected = false;
  let selectedImgName = null;
  let imageAnimationWaitTime = 150;
  let currentImageUrl = window.location.href;
  let activeErrorPopup = null;
  let errorPopupHideTimeout = null;
  let errorPopupRemoveTimeout = null;
  let imageTransitionToken = 0;

  function createLetterArrays() {
    return {
      A: [0,1,2,3,4], B: [0,1], C: [0,1,2], D: [0,1], E: [0,1,2,3],
      F: [0,1], G: [0], H: [0,1], I: [0,1,2,3,4], J: [0,1,2],
      K: [0,1], L: [0,1,2,3], M: [0,1,2], N: [0,1,2], O: [0,1],
      P: [0,1], Q: [0,1], R: [0,1,2,3], S: [0,1,2], T: [0,1],
      U: [0,1], V: [0,1,2,3], W: [0,1], X: [0,1,2], Y: [0,1,2],
      Z: [0,1]
    };
  }

  function getRandomInt(min, max) {
    return Math.floor(Math.random() * (max - min + 1)) + min;
  }

  function getRandomBadWordResponse() {
    return badWordResponses[getRandomInt(0, badWordResponses.length - 1)];
  }

  function containsBadWords(text) {
    const normalizedText = text.toLowerCase();
    return badWords.some(badWord => {
      const regex = new RegExp(`\\b${badWord}\\b`, 'i');
      return regex.test(normalizedText);
    });
  }

  function convertRange(value, r1, r2) {
    return (value - r1[0]) * (r2[1] - r2[0]) / (r1[1] - r1[0]) + r2[0];
  }

  function pickLetterImage(letter, forcedIndex = null) {
    const upperLetter = letter.toUpperCase();
    const arrays = createLetterArrays();
    const pool = arrays[upperLetter];
    if (!pool) return 'a_0';

    // If forcedIndex is provided and valid, use it
    if (forcedIndex !== null && forcedIndex !== undefined && forcedIndex !== '') {
      const idx = parseInt(forcedIndex);
      if (!isNaN(idx) && pool.includes(idx)) {
        return `${letter.toLowerCase()}_${idx}`;
      }
      // Invalid index - fallback to random
    }

    if (pool.length > 0) {
      const index = getRandomInt(0, pool.length - 1);
      const number = pool[index];
      pool.splice(index, 1);
      return `${letter.toLowerCase()}_${number}`;
    }
    return `${letter.toLowerCase()}_0`;
  }

  function parseSequenceForWord(word, sequence) {
    if (!word || typeof word !== 'string' || !sequence || typeof sequence !== 'string') {
      return null;
    }

    const normalizedSequence = sequence.replace(/\s+/g, '');
    if (!normalizedSequence) return null;

    const result = [];
    let sequenceIndex = 0;

    for (const char of word) {
      if (char === ' ') {
        result.push({ char: ' ', index: null });
        continue;
      }

      const digit = normalizedSequence[sequenceIndex];
      const index = digit !== undefined && /\d/.test(digit) ? parseInt(digit, 10) : null;
      result.push({ char, index });

      if (digit !== undefined) {
        sequenceIndex += 1;
      }
    }

    return result;
  }

  function buildSequenceFromImageCodes(imageCodes) {
    return imageCodes
      .filter((code) => code !== 'blank')
      .map((code) => code.split('_')[1] || '0')
      .join('');
  }

  function toggleImageActive(i, img) {
    setTimeout(() => img.classList.toggle('active'), imageAnimationWaitTime * i);
  }

  function wait(ms) {
    return new Promise((resolve) => {
      setTimeout(resolve, ms);
    });
  }

  async function animateExistingImagesOut(token) {
    const nameBoxes = document.getElementById('nameBoxes');
    if (!nameBoxes) return;

    const existingChildren = Array.from(nameBoxes.children);
    if (!existingChildren.length) {
      nameBoxes.innerHTML = '';
      return;
    }

    hideLocationInfo();
    existingChildren.forEach((child) => child.classList.remove('selected'));

    existingChildren.forEach((child, index) => {
      if (token !== imageTransitionToken) return;
      toggleImageActive(index, child);
    });

    await wait(existingChildren.length * imageAnimationWaitTime + 250);

    if (token !== imageTransitionToken) return;
    nameBoxes.innerHTML = '';
  }

  async function transitionToImages(input, parsedValue = null) {
    const token = ++imageTransitionToken;
    await animateExistingImagesOut(token);
    if (token !== imageTransitionToken) return;
    createImages(input, parsedValue);
  }

  async function clearImagesWithTransition() {
    const token = ++imageTransitionToken;
    await animateExistingImagesOut(token);
  }

  function showLocationInfo(name) {
    const locationTitle = document.getElementById('locationTitle');
    const locationCoordinates = document.getElementById('locationCoordinates');
    if (!locationTitle || !locationCoordinates) return;

    const letter = name.split('_')[0].toLowerCase();
    const idx = parseInt(name.split('_')[1], 10);
    const entries = letterData[letter];

    if (entries && entries[idx]) {
      const entry = entries[idx];
      locationTitle.textContent = entry.location;

      // Handle link: use # for invalid links
      let linkUrl = entry.link;
      if (linkUrl === 'https://none.com' || !linkUrl || linkUrl === '') {
        linkUrl = '#';
      }
      locationTitle.href = linkUrl;

      locationCoordinates.textContent = entry.coordinates;

      // Handle maps: use Google Maps search for generic/unknown maps
      let mapsUrl = entry.maps;
      if (mapsUrl === 'https://maps.google.com' || !mapsUrl || mapsUrl === '') {
        // Build Google Maps search URL from coordinates
        const coords = entry.coordinates;
        mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(coords)}`;
      }
      locationCoordinates.href = mapsUrl;
    } else {
      locationTitle.textContent = '';
      locationTitle.href = '#';
      locationCoordinates.textContent = '';
      locationCoordinates.href = '#';
    }
  }

  function hideLocationInfo() {
    const locationTitle = document.getElementById('locationTitle');
    const locationCoordinates = document.getElementById('locationCoordinates');
    if (locationTitle) locationTitle.href = '#';
    if (locationCoordinates) locationCoordinates.href = '#';
    imageSelected = false;
    selectedImgName = null;
  }

  function trimCanvas(canvas) {
    const ctx = canvas.getContext('2d');
    const { width, height } = canvas;
    const imageData = ctx.getImageData(0, 0, width, height);
    const data = imageData.data;

    let top = null, bottom = null, left = null, right = null;
    for (let y = 0; y < height; y++) {
      for (let x = 0; x < width; x++) {
        const alpha = data[4 * (y * width + x) + 3];
        if (alpha > 0) {
          if (top === null) top = y;
          bottom = y;
          if (left === null || x < left) left = x;
          if (right === null || x > right) right = x;
        }
      }
    }

    if (top === null || left === null || right === null || bottom === null) return canvas;

    const trimmedWidth = right - left + 1;
    const trimmedHeight = bottom - top + 1;
    const trimmedCanvas = document.createElement('canvas');
    trimmedCanvas.width = trimmedWidth;
    trimmedCanvas.height = trimmedHeight;
    const trimmedCtx = trimmedCanvas.getContext('2d');
    trimmedCtx.drawImage(canvas, left, top, trimmedWidth, trimmedHeight, 0, 0, trimmedWidth, trimmedHeight);
    return trimmedCanvas;
  }

  function createImages(input, parsedValue = null) {
    const nameBoxes = document.getElementById('nameBoxes');
    const textBelowTitle = document.getElementById('textBelowTitle');
    if (!nameBoxes) return;

    nameBoxes.innerHTML = '';
    if (textBelowTitle) textBelowTitle.classList.remove('active');

    // Determine if using parsed value from URL or plain text input
    const useParsed = parsedValue && Array.isArray(parsedValue);
    const displayText = useParsed ? parsedValue.map(p => p.char).join('') : input;

    const gap = convertRange(displayText.length, [1, 50], [1, 0.1]);
    nameBoxes.style.gap = gap + '%';

    let currentCustomLink = [];

    for (let i = 0; i < displayText.length; i++) {
      const char = displayText[i];

      if (char === ' ') {
        const blankDiv = document.createElement('div');
        blankDiv.classList.add('blankDiv');
        blankDiv.style.width = convertRange(displayText.length, [1, 50], [2, 5]) + '%';
        nameBoxes.appendChild(blankDiv);
        currentCustomLink.push('blank');
      } else {
        const img = document.createElement('img');
        img.setAttribute('draggable', 'false');

        // Get forced index if available from parsed value
        const forcedIndex = useParsed ? parsedValue[i]?.index : null;
        const name = pickLetterImage(char, forcedIndex);

        img.src = `${imagesBasePath}/letter_${name}.webp`;
        img.alt = name;

        img.addEventListener('mouseover', () => {
          if (!imageSelected) showLocationInfo(name);
        });

        // Only show on mouseover - clicking an image will pin the location info
        img.addEventListener('click', () => {
          const title = document.getElementById('locationTitle');
          if (!title) return;

          if (imageSelected && selectedImgName === name) {
            // Click same image = deselect
            img.classList.remove('selected');
            imageSelected = false;
            selectedImgName = null;
            hideLocationInfo();
          } else {
            // Select this image
            nameBoxes.querySelectorAll('img.selected').forEach(el => el.classList.remove('selected'));
            img.classList.add('selected');
            imageSelected = true;
            selectedImgName = name;
            showLocationInfo(name);
          }
        });

        nameBoxes.appendChild(img);
        currentCustomLink.push(name);
        setTimeout(() => toggleImageActive(i, img), imageAnimationWaitTime);
      }
    }

    generateShareUrl(displayText, currentCustomLink);
  }

  function generateShareUrl(displayText, customLink) {
    const params = new URLSearchParams();
    const trimmedDisplayText = displayText.trim();
    const sequence = buildSequenceFromImageCodes(customLink);
    if (sequence) {
      params.set('v', sequence);
    }

    const pathname = trimmedDisplayText ? `/${encodeURIComponent(trimmedDisplayText)}` : '/';
    const query = params.toString();
    currentImageUrl = `${window.location.origin}${pathname}${query ? `?${query}` : ''}`;

    const qrImg = document.getElementById('qr-img');
    if (qrImg && typeof QRCode !== 'undefined' && currentImageUrl) {
      // Generate QR code as data URL using Promise
      QRCode.toDataURL(currentImageUrl, {
        width: 200,
        margin: 1,
        color: {
          dark: '#000000',
          light: '#ffffff'
        }
      }).then((url) => {
        if (url) {
          qrImg.src = url;
        }
      }).catch(() => {});
    }
  }

  function getExportName() {
    const nameInput = document.getElementById('nameInput');
    return (nameInput?.value || 'landsat-name') + '.png';
  }

  async function exportAsPng() {
    const nameBoxes = document.getElementById('nameBoxes');
    if (!nameBoxes || typeof html2canvas === 'undefined') return;

    try {
      const canvas = await html2canvas(nameBoxes, { backgroundColor: null, scale: 2 });

      const trimmed = trimCanvas(canvas);
      const link = document.createElement('a');
      link.href = trimmed.toDataURL('image/png');
      link.download = getExportName();
      link.click();
    } catch (e) {
      console.error('Export failed:', e);
    }
  }

  function downloadQrCode() {
    const qrImg = document.getElementById('qr-img');
    const nameInput = document.getElementById('nameInput');
    if (!(qrImg instanceof HTMLImageElement) || !qrImg.src) return;

    const link = document.createElement('a');
    const baseName = (nameInput?.value || 'landsat-name').trim() || 'landsat-name';
    link.href = qrImg.src;
    link.download = `${baseName}-qr.png`;
    link.click();
  }

  async function showQRPopup() {
    const qrPopup = document.getElementById('qr-popup');
    const finalImg = document.getElementById('final-img');
    const nameBoxes = document.getElementById('nameBoxes');
    if (!qrPopup) return;

    qrPopup.classList.add('active');

    if (finalImg && nameBoxes && typeof html2canvas !== 'undefined') {
      try {
        const canvas = await html2canvas(nameBoxes, { backgroundColor: null, scale: 2 });

        const trimmed = trimCanvas(canvas);
        finalImg.src = trimmed.toDataURL('image/png');
        finalImg.style.display = 'block';
      } catch (e) {
        if (finalImg) finalImg.style.display = 'none';
      }
    }
  }

  function hideQRPopup() {
    const qrPopup = document.getElementById('qr-popup');
    if (qrPopup) qrPopup.classList.remove('active');
  }

  function showAboutPopup() {
    const aboutPopup = document.getElementById('about-popup');
    if (aboutPopup) aboutPopup.classList.add('active');
  }

  function hideAboutPopup() {
    const aboutPopup = document.getElementById('about-popup');
    if (aboutPopup) aboutPopup.classList.remove('active');
  }

  function hideHelpPopup() {
    const helpContainer = document.getElementById('helpContainer');
    if (helpContainer) helpContainer.classList.remove('active');
  }

  function copyLink() {
    const copyText = document.getElementById('qr-copy-link-text');
    const copyIcon = document.getElementById('qr-copy-link-icon');

    navigator.clipboard.writeText(currentImageUrl).then(() => {
      if (copyText) copyText.textContent = 'Link Copied';
      if (copyIcon) copyIcon.className = 'fas fa-check';
      setTimeout(() => {
        if (copyText) copyText.textContent = 'Copy Link';
        if (copyIcon) copyIcon.className = 'fas fa-link';
      }, 3000);
    }).catch(() => {});
  }

  function showErrorPopup(message) {
    const inputPopup = document.getElementById('inputPopup');
    const container = document.getElementById('container');
    if (!inputPopup || !container) return;

    if (!activeErrorPopup || !activeErrorPopup.isConnected) {
      activeErrorPopup = inputPopup.cloneNode(true);
      activeErrorPopup.removeAttribute('id');
      activeErrorPopup.classList.remove('popup-template');
      activeErrorPopup.classList.add('runtime-popup');

      const popupText = activeErrorPopup.querySelector('#popupText');
      if (popupText) {
        popupText.removeAttribute('id');
      }

      container.appendChild(activeErrorPopup);
    }

    const popupText = activeErrorPopup.querySelector('p');
    if (popupText) {
      popupText.textContent = message;
    }

    if (errorPopupHideTimeout) {
      clearTimeout(errorPopupHideTimeout);
      errorPopupHideTimeout = null;
    }

    if (errorPopupRemoveTimeout) {
      clearTimeout(errorPopupRemoveTimeout);
      errorPopupRemoveTimeout = null;
    }

    requestAnimationFrame(() => {
      if (activeErrorPopup) activeErrorPopup.classList.add('active');
    });

    errorPopupHideTimeout = setTimeout(() => {
      if (activeErrorPopup) activeErrorPopup.classList.remove('active');
      errorPopupRemoveTimeout = setTimeout(() => {
        if (activeErrorPopup) activeErrorPopup.remove();
        activeErrorPopup = null;
        errorPopupRemoveTimeout = null;
      }, 250);
      errorPopupHideTimeout = null;
    }, 5000);
  }

  function hideErrorPopup() {
    if (errorPopupHideTimeout) {
      clearTimeout(errorPopupHideTimeout);
      errorPopupHideTimeout = null;
    }

    if (errorPopupRemoveTimeout) {
      clearTimeout(errorPopupRemoveTimeout);
      errorPopupRemoveTimeout = null;
    }

    if (activeErrorPopup) {
      activeErrorPopup.remove();
      activeErrorPopup = null;
    }
  }

  async function enterButtonClick() {
    const nameInput = document.getElementById('nameInput');
    const textBelowTitle = document.getElementById('textBelowTitle');

    if (!nameInput) return;

    const input = nameInput.value.trim();

    if (!input) {
      await clearImagesWithTransition();
      hideLocationInfo();
      return;
    }

    const hasLetters = /^[ A-Za-z]+$/.test(input);
    if (!hasLetters) {
      showErrorPopup('Please only enter letters from A-Z');
      return;
    }

    if (containsBadWords(input)) {
      showErrorPopup(getRandomBadWordResponse());
      return;
    }

    hideErrorPopup();
    if (textBelowTitle) textBelowTitle.classList.remove('active');
    await transitionToImages(input);
  }

  function init() {
    const nameForm = document.getElementById('container');
    const nameInput = document.getElementById('nameInput');
    const qrCloseButton = document.getElementById('qr-close-btn');
    const qrPopup = document.getElementById('qr-popup');
    const copyLinkBtn = document.getElementById('qr-copy-link-btn');
    const qrDownloadBtn = document.getElementById('qr-download-btn');
    const downloadBtn = document.getElementById('downloadBtn');
    const qrCodeBtn = document.getElementById('qrCodeBtn');
    const aboutBtn = document.getElementById('aboutBtn');
    const aboutPopup = document.getElementById('about-popup');
    const aboutCloseBtn = document.getElementById('about-close-btn');
    const helpIcon = document.getElementById('helpIcon');
    const helpContainer = document.getElementById('helpContainer');
    const helpCloseBtn = document.getElementById('help-close-btn');

    // Filter input
    if (nameInput) {
      nameInput.addEventListener('input', () => {
        nameInput.value = nameInput.value.replace(/[^a-zA-Z ]/g, '');
      });
    }

    if (nameForm) {
      nameForm.addEventListener('submit', (e) => {
        e.preventDefault();
        enterButtonClick();
      });
    }

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        hideQRPopup();
        hideAboutPopup();
        hideHelpPopup();
      }
    });

    if (downloadBtn) {
      downloadBtn.addEventListener('click', (e) => {
        e.preventDefault();
        exportAsPng();
      });
    }

    if (qrCodeBtn) {
      qrCodeBtn.addEventListener('click', (e) => {
        e.preventDefault();
        showQRPopup();
      });
    }

    if (qrDownloadBtn) {
      qrDownloadBtn.addEventListener('click', downloadQrCode);
    }

    if (qrCloseButton) {
      qrCloseButton.addEventListener('click', hideQRPopup);
    }

    if (qrPopup) {
      qrPopup.addEventListener('click', (e) => {
        if (e.target === qrPopup) hideQRPopup();
      });
    }

    if (aboutBtn) {
      aboutBtn.addEventListener('click', showAboutPopup);
    }

    if (aboutCloseBtn) {
      aboutCloseBtn.addEventListener('click', hideAboutPopup);
    }

    if (aboutPopup) {
      aboutPopup.addEventListener('click', (e) => {
        if (e.target === aboutPopup) hideAboutPopup();
      });
    }

    if (copyLinkBtn) {
      copyLinkBtn.addEventListener('click', copyLink);
    }

    // Help
    if (helpIcon) {
      helpIcon.addEventListener('click', (e) => {
        e.stopPropagation();
        if (!helpContainer) return;

        if (helpContainer.classList.contains('active')) {
          hideHelpPopup();
        } else {
          const rect = helpIcon.getBoundingClientRect();
          const viewportWidth = window.innerWidth;
          const popupWidth = 220;

          // Calculate left position
          let leftPos;
          if (rect.right + popupWidth + 10 < viewportWidth) {
            leftPos = rect.right + 5;
          } else {
            leftPos = rect.left - popupWidth - 10;
          }

          // Position: top of popup aligns with top of icon, then transform up
          helpContainer.style.left = leftPos + 'px';
          helpContainer.style.top = rect.top + 'px';
          helpContainer.style.transform = 'translateY(-100%)';
          helpContainer.classList.add('active');
        }
      });
    }

    if (helpCloseBtn) {
      helpCloseBtn.addEventListener('click', hideHelpPopup);
    }

    document.addEventListener('click', (e) => {
      if (
        helpContainer &&
        helpContainer.classList.contains('active') &&
        !e.target.closest('.helpContainer') &&
        !e.target.closest('.help-icon')
      ) {
        hideHelpPopup();
      }
    });

    document.addEventListener('click', (e) => {
      const nameBoxes = document.getElementById('nameBoxes');
      if (!nameBoxes) return;

      if (e.target.tagName === 'IMG' && nameBoxes.contains(e.target)) return;
      if (e.target.id === 'locationTitle') return;
      if (e.target.id === 'locationCoordinates') return;
      if (e.target.closest('.bottom-controls')) return;
      if (e.target.closest('.helpContainer')) return;
      if (e.target.closest('.help-icon')) return;

      // Click outside clears selection but keeps location info visible
      if (imageSelected) {
        nameBoxes.querySelectorAll('img.selected').forEach(el => el.classList.remove('selected'));
        imageSelected = false;
        selectedImgName = null;
      }
    });

    // Initial load - use the slug as the displayed text and optionally
    // consume the v sequence across letters only, skipping spaces.
    let wordToShow = initialWord;
    let parsedForImages = null;

    if (initialWord && typeof initialWord === 'string' && initialWord.trim()) {
      parsedForImages = parseSequenceForWord(initialWord, initialSequence);
    }

    createImages(wordToShow, parsedForImages);
    if (nameInput && wordToShow) {
      nameInput.value = wordToShow;
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

